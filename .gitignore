# CMake generated files and directories
# Use a common build directory name, e.g., 'build/' or 'out/'
build/
out/
cmake-build-*/  # For IDEs like CLion

# Specific CMake files
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
.cmake/api/
_deps/

# IDE/Editor specific files
.vscode/     # VS Code
.idea/       # JetBrains IDEs (CLion, etc)
*.suo
*.user
*.config.cache
*.ntvs*
*.sln        # Visual Studio Solution files - check in if shared across team, ignore if auto-generated
*.vcxproj*   # Visual Studio Project files
*.filters

# Operating System generated files
.DS_Store    # macOS
Thumbs.db    # Windows

# Generated build artifacts (executables, libraries, object files)
*.o
*.obj
*.d
*.bin
*.exe
*.dll
*.lib
*.a
# Specific directories for build results if not in 'build/'
[Dd]ebug/
[Rr]elease/

# Log and documentation files
*.log
*.logs
/docs/html/ # If Doxygen documentation is generated here
